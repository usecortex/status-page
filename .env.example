# incident.io Widget API URL (get from incident.io dashboard > Status Pages > Widget API)
INCIDENT_IO_WIDGET_URL=

# AWS S3 credentials for status data storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=hydradb-status-data
S3_REGION=us-east-1

# Vercel Cron secret (auto-set by Vercel, used to secure /api/cron)
CRON_SECRET=

# (Optional) Override the status data URL for local development.
# When set, the frontend fetches from this URL instead of the S3 public URL.
# Example: STATUS_DATA_URL=http://localhost:3000/status.json
STATUS_DATA_URL=
